15:["$","p",null,{"className":"text-neutral-500 text-base leading-relaxed mb-6","children":["If you are looking through the list of top engineering consultant companies Abu Dhabi, then connect with us today. Give us a call at ",["$","a",null,{"className":"text-primary","href":"tel:+971 50 618 5529","children":" +971 50 618 5529"}]," to schedule a meeting. You can also drop us an email at ",["$","a",null,{"className":"text-primary","href":"mailto:info@enmaaengcon.com","children":"info@enmaaengcon.com"}]," We are just a call away to bring your ideal imagination into a proper functional design."]}]
